# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git — it contains secret keys.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Settings → API

# Public URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key — safe to expose (Row Level Security protects the data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER ONLY, never prefix with NEXT_PUBLIC_
# Has full DB access, bypasses RLS — treat like a password
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Groq (AI — free tier) ───────────────────────────────────────────────────
# Find at: console.groq.com → API Keys
# SERVER ONLY — never prefix with NEXT_PUBLIC_
GROQ_API_KEY=gsk_...

# ─── Lemon Squeezy ────────────────────────────────────────────────────────────
# Find at: app.lemonsqueezy.com → Settings → API

# API key — SERVER ONLY
LEMONSQUEEZY_API_KEY=

# Store ID — find at: app.lemonsqueezy.com → Settings → Stores (the number in the URL)
LEMONSQUEEZY_STORE_ID=

# Variant ID — find at: your product → Variants → click variant → number in URL
LEMONSQUEEZY_VARIANT_ID=

# Webhook signing secret — SERVER ONLY
# Set at: app.lemonsqueezy.com → Settings → Webhooks → Add endpoint
# URL: http://localhost:3000/api/lemonsqueezy/webhook (dev) or your prod URL
# Events: subscription_created, subscription_cancelled, subscription_expired, subscription_updated
LEMONSQUEEZY_WEBHOOK_SECRET=secreta

# ─── App ──────────────────────────────────────────────────────────────────────
# Your deployed URL (used for Stripe redirect URLs)
# Use http://localhost:3000 for local development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Find at: resend.com → API Keys
# SERVER ONLY
RESEND_API_KEY=re_...


LEMONSQUEEZY_WEBHOOK_SECRET=e2ea95f36f3f4569444b03c8417f6ccf04695d7c

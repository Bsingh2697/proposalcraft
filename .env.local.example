# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git — it contains secret keys.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Settings → API

# Public URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key — safe to expose (Row Level Security protects the data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER ONLY, never prefix with NEXT_PUBLIC_
# Has full DB access, bypasses RLS — treat like a password
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Anthropic (Claude AI) ────────────────────────────────────────────────────
# Find at: console.anthropic.com → API Keys
# SERVER ONLY — never prefix with NEXT_PUBLIC_
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Find at: dashboard.stripe.com → Developers → API Keys

# Publishable key — safe for the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret key — SERVER ONLY
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — SERVER ONLY
# Get this from: Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
# For local testing: run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
#   and copy the whsec_... secret it prints
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID of your "ProposalCraft Pro" $9/month product
# Find at: Stripe dashboard → Products → ProposalCraft Pro → copy the Price ID
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...

# ─── App ──────────────────────────────────────────────────────────────────────
# Your deployed URL (used for Stripe redirect URLs)
# Use http://localhost:3000 for local development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Find at: resend.com → API Keys
# SERVER ONLY
RESEND_API_KEY=re_...
